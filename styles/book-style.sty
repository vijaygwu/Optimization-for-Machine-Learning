    \vspace{0.5em}%
    \hrule%
    \vspace{0.5em}%
    \parindent0pt%
}{%
    \vspace{0.5em}%
    \hrule%
    \vspace{1em}%
}

%------------------------------------------------------------------------------
%  QR CODE COMMANDS
%------------------------------------------------------------------------------

% Notebook QR code box - for linking to Jupyter notebooks
\newcommand{\notebookqr}[1]{%
    \begin{tcolorbox}[
        colback=gray!5!white,
        colframe=gray!50!black,
        width=3.5cm,
        boxrule=0.5pt,
        arc=3pt,
        left=2pt,
        right=2pt,
        top=2pt,
        bottom=2pt
    ]
    \centering
    \qrcode[height=1.3cm]{#1}\\[0.2em]
    {\scriptsize\faLaptopCode\ Interactive Notebook}
    \end{tcolorbox}
}

% Inline notebook link with description
\newcommand{\notebooklink}[2]{%
    \marginpar{%
        \centering
        \qrcode[height=1.2cm]{#1}\\[0.2em]
        {\scriptsize #2}
    }%
}

%------------------------------------------------------------------------------
