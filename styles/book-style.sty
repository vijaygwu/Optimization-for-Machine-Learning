%------------------------------------------------------------------------------
%  HEADER AND FOOTER
%------------------------------------------------------------------------------
\RequirePackage{fancyhdr}

\pagestyle{fancy}
\fancyhf{}

% Header
\fancyhead[LE]{\small\textit{\nouppercase{\leftmark}}}
\fancyhead[RO]{\small\textit{\nouppercase{\rightmark}}}

% Footer
\fancyfoot[LE,RO]{\thepage}
\fancyfoot[RE,LO]{\small\textit{Mathematics to Machines}}

% Header/Footer Rules
\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\footrulewidth}{0.2pt}

% Plain style for chapter pages
\fancypagestyle{plain}{
    \fancyhf{}
    \fancyfoot[C]{\thepage}
    \renewcommand{\headrulewidth}{0pt}
    \renewcommand{\footrulewidth}{0.2pt}
}

%------------------------------------------------------------------------------
%  CHAPTER AND SECTION STYLING
%------------------------------------------------------------------------------
\RequirePackage{titlesec}

% Chapter Style
\titleformat{\chapter}[display]
    {\normalfont\huge\bfseries\color{primaryblue}}
    {\chaptertitlename\ \thechapter}
    {20pt}
    {\Huge}

\titlespacing*{\chapter}{0pt}{-20pt}{40pt}

% Section Styles
\titleformat{\section}
    {\normalfont\Large\bfseries\color{primaryblue}}
    {\thesection}
    {1em}
    {}

\titleformat{\subsection}
    {\normalfont\large\bfseries\color{primaryblue!80}}
    {\thesubsection}
    {1em}
    {}

\titleformat{\subsubsection}
    {\normalfont\normalsize\bfseries\color{primaryblue!60}}
    {\thesubsubsection}
    {1em}
    {}

%------------------------------------------------------------------------------
%  PART STYLING
%------------------------------------------------------------------------------
\titleformat{\part}[display]
    {\centering\normalfont\Huge\bfseries\color{primaryblue}}
    {\partname\ \thepart}
    {20pt}
    {\Huge}

%------------------------------------------------------------------------------
%  TABLE OF CONTENTS STYLING
%------------------------------------------------------------------------------
\RequirePackage{tocloft}

\renewcommand{\cftpartfont}{\bfseries\large\color{primaryblue}}
\renewcommand{\cftchapfont}{\bfseries\color{primaryblue!80}}
\renewcommand{\cftsecfont}{\color{black}}
\renewcommand{\cftsubsecfont}{\color{black!70}}

\renewcommand{\cftpartpagefont}{\bfseries\large\color{primaryblue}}
\renewcommand{\cftchappagefont}{\bfseries\color{primaryblue!80}}

%------------------------------------------------------------------------------
%  PARAGRAPH SETTINGS
%------------------------------------------------------------------------------
\setlength{\parskip}{0.5em}
\setlength{\parindent}{0pt}

%------------------------------------------------------------------------------
%  CAPTION STYLING
%------------------------------------------------------------------------------
\captionsetup{
    font=small,
    labelfont={bf,color=primaryblue},
