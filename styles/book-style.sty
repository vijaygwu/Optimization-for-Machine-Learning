% Difficulty Rating Command
\newcommand{\difficulty}[1]{%
    \textbf{Difficulty:} %
    \foreach \i in {1,...,3}{%
        \ifnum\i>#1 \faStarO\else\faStar\fi%
    }%
}

% Interview Questions Box
