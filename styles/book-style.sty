}

%------------------------------------------------------------------------------
%  ALGORITHM STYLING
%------------------------------------------------------------------------------
\algrenewcommand\algorithmicrequire{\textbf{Input:}}
\algrenewcommand\algorithmicensure{\textbf{Output:}}

% Custom algorithm commands
\algnewcommand\algorithmicforeach{\textbf{for each}}
\algdef{S}[FOR]{ForEach}[1]{\algorithmicforeach\ #1\ \algorithmicdo}

%------------------------------------------------------------------------------
%  MATH OPERATORS AND COMMANDS
%------------------------------------------------------------------------------

% Operators
\DeclareMathOperator*{\argmax}{arg\,max}
\DeclareMathOperator*{\argmin}{arg\,min}
\DeclareMathOperator{\tr}{tr}
\DeclareMathOperator{\diag}{diag}
\DeclareMathOperator{\rank}{rank}
\DeclareMathOperator{\Var}{Var}
\DeclareMathOperator{\Cov}{Cov}
\DeclareMathOperator{\E}{\mathbb{E}}
\DeclareMathOperator{\Prob}{\mathbb{P}}
\DeclareMathOperator{\sign}{sign}
\DeclareMathOperator{\softmax}{softmax}
\DeclareMathOperator{\ReLU}{ReLU}
\DeclareMathOperator{\sigmoid}{\sigma}

% Number Sets
\newcommand{\R}{\mathbb{R}}
\newcommand{\N}{\mathbb{N}}
\newcommand{\Z}{\mathbb{Z}}
\newcommand{\Q}{\mathbb{Q}}
\newcommand{\C}{\mathbb{C}}

% Vectors and Matrices
\newcommand{\vect}[1]{\boldsymbol{#1}}
\newcommand{\mat}[1]{\mathbf{#1}}
\newcommand{\trans}{^\top}
\newcommand{\inv}{^{-1}}

% Norms and Brackets
\newcommand{\norm}[1]{\left\lVert #1 \right\rVert}
\newcommand{\abs}[1]{\left| #1 \right|}
\newcommand{\inner}[2]{\left\langle #1, #2 \right\rangle}
\newcommand{\set}[1]{\left\{ #1 \right\}}
\newcommand{\ceil}[1]{\left\lceil #1 \right\rceil}
\newcommand{\floor}[1]{\left\lfloor #1 \right\rfloor}

% Derivatives
\newcommand{\dd}{\mathrm{d}}
\newcommand{\pd}[2]{\frac{\partial #1}{\partial #2}}
\newcommand{\pdd}[2]{\frac{\partial^2 #1}{\partial #2^2}}
\newcommand{\grad}{\nabla}
\newcommand{\Hess}{\mathbf{H}}

% Probability
\newcommand{\given}{\,|\,}
\newcommand{\iid}{\stackrel{\text{iid}}{\sim}}
\newcommand{\KL}[2]{D_{\mathrm{KL}}\left( #1 \,\|\, #2 \right)}

%------------------------------------------------------------------------------
%  TCOLORBOX SETUP (for styled boxes)
%------------------------------------------------------------------------------
\RequirePackage[most]{tcolorbox}

\tcbset{
    basebox/.style={
        enhanced,
        breakable=false,
        arc=2mm,
        boxrule=0.8pt,
        left=8pt,
        right=8pt,
        top=8pt,
        bottom=8pt,
        fonttitle=\bfseries,
        before upper={\parindent0pt},
        % Prevent orphaned box headers - ensure minimum content before break
        before={\par\needspace{6\baselineskip}},
        pad before break=2mm,
        pad after break=2mm,
        % Repeat title on continuation pages for multi-page boxes
        extras middle and last={
            title={\thetcbtitle\ \emph{(continued)}}
        }
    }
}

%------------------------------------------------------------------------------
%  CUSTOM ENVIRONMENTS - KEY CONCEPTS
%------------------------------------------------------------------------------

% Key Concept Box
\newtcolorbox{keyconcept}[1][]{
    basebox,
    colback=thmbackground,
    colframe=thmframe,
    title=Key Concept,
    #1
}

% Important Note Box
\newtcolorbox{important}[1][]{
    basebox,
    colback=warnbackground,
    colframe=warnframe,
    title=Important,
    #1
}

% Note Box
\newtcolorbox{notebox}[1][]{
    basebox,
    colback=notebackground,
    colframe=noteframe,
    title=Note,
    #1
}

% Intuition Box (non-breakable to keep content together)
\newtcolorbox{intuition}[1][Intuition]{
    basebox,
    breakable=false,
    colback=exbackground,
    colframe=exframe,
    title=#1
}

% Principle Box
\newtcolorbox{principle}[1][]{
    basebox,
    colback=defbackground,
    colframe=defframe,
    title=Principle,
    #1
}

% Perspective Box
\newtcolorbox{perspective}[1][]{
    basebox,
    colback=accentpurple!5,
    colframe=accentpurple!70!black,
    title=Perspective,
    #1
}

% Warning Box
\newtcolorbox{warning}[1][]{
    basebox,
    colback=warnbackground,
    colframe=warnframe,
    title=Warning,
    #1
}

% ML Application Box (for machine learning motivation examples)
\newtcolorbox{mlbox}[1]{
    basebox,
    colback=primaryblue!5,
    colframe=primaryblue!70!black,
    title=#1,
}

