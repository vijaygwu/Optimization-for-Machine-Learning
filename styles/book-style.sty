% Default TikZ Styles
\tikzset{
    vector/.style={->,thick,>=Stealth},
    axis/.style={thick,->,>=Latex},
    point/.style={circle,fill,inner sep=1.5pt},
    node/.style={circle,draw,minimum size=8mm},
    hidden/.style={circle,draw,fill=blue!20,minimum size=8mm},
    input/.style={circle,draw,fill=green!20,minimum size=8mm},
    output/.style={circle,draw,fill=red!20,minimum size=8mm},
