%==============================================================================
%  CODE-STYLE.STY
%  Code listing styles for "Mathematics to Machines"
%  Author: Dr. Vijay Raghavan
%==============================================================================

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{styles/code-style}[2026/04/11 Code Style Package]

%------------------------------------------------------------------------------
%  REQUIRED PACKAGES
%------------------------------------------------------------------------------
\RequirePackage{listings}
\RequirePackage{xcolor}
\RequirePackage[most]{tcolorbox}
\tcbuselibrary{listings,skins,breakable}
\RequirePackage{fontawesome5}

%------------------------------------------------------------------------------
%  CODE COLOR PALETTE (Modern, clean style inspired by technical books)
%------------------------------------------------------------------------------

% Background and Border - soft blue-gray
\definecolor{codeBackground}{RGB}{237,241,246}  % Light blue-gray background
\definecolor{codeBorder}{RGB}{220,225,232}      % Subtle border
\definecolor{codeLineNum}{RGB}{140,150,160}     % Muted line numbers

% Syntax Highlighting - Modern Python Style
\definecolor{codeKeyword}{RGB}{0,75,135}        % Navy blue - keywords (import, for, in, if)
\definecolor{codeString}{RGB}{163,21,21}        % Red - strings
\definecolor{codeComment}{RGB}{120,130,140}     % Gray - comments
\definecolor{codeFunction}{RGB}{0,128,128}      % Teal - functions/methods
\definecolor{codeNumber}{RGB}{192,90,20}        % Orange - numbers
\definecolor{codeClass}{RGB}{0,128,128}         % Teal - classes
\definecolor{codeDecorator}{RGB}{175,0,219}     % Purple - decorators
\definecolor{codeBuiltin}{RGB}{0,128,128}       % Teal - builtins (np, plt, torch)
\definecolor{codeOperator}{RGB}{50,50,50}       % Dark gray - operators
\definecolor{codeSelf}{RGB}{0,75,135}           % Navy - self/cls

% Console Colors
\definecolor{consoleBackground}{RGB}{30,30,30}
\definecolor{consoleText}{RGB}{204,204,204}
\definecolor{consolePrompt}{RGB}{78,201,176}
\definecolor{consoleOutput}{RGB}{156,220,254}

%------------------------------------------------------------------------------
%  PYTHON STYLE (Clean, modern look)
%------------------------------------------------------------------------------
\lstdefinestyle{pythonstyle}{
    language=Python,
    % Basic formatting - generous spacing
    basicstyle=\ttfamily\scriptsize\linespread{1.1}\selectfont,
    backgroundcolor=\color{codeBackground},
    % Syntax highlighting
    keywordstyle=\color{codeKeyword}\bfseries,
    stringstyle=\color{codeString},
    commentstyle=\color{codeComment},
    identifierstyle=\color{black!85},
    % Additional keywords
    morekeywords={self,True,False,None,as,with,yield,lambda,async,await,cls},
    % Library/module names in teal
    emph={torch,tf,np,pd,plt,nn,optim,F,sklearn,scipy,rng,random,linalg,math},
    emphstyle=\color{codeBuiltin},
    % Function/method names
    emph={[2]__init__,forward,backward,fit,predict,transform,default_rng,standard_normal,random,mean,std,reshape,dot,matmul,zeros,ones,array,linspace,arange},
    emphstyle={[2]\color{codeFunction}},
    % No line numbers by default (cleaner look)
    numbers=none,
    numberstyle=\tiny\color{codeLineNum},
    numbersep=12pt,
    stepnumber=1,
    % Frame - minimal/invisible
    frame=none,
    framesep=0pt,
    framerule=0pt,
    % Minimal margins
    xleftmargin=4pt,
    xrightmargin=4pt,
    % Spacing
    aboveskip=8pt,
    belowskip=8pt,
    tabsize=4,
    % Line breaking
    breaklines=true,
    breakatwhitespace=true,
    breakindent=20pt,
    postbreak=\mbox{\textcolor{codeLineNum}{$\hookrightarrow$}\space},
    % Misc
    showstringspaces=false,
    keepspaces=true,
    captionpos=b,
    % Number highlighting (orange for numeric literals)
    literate=
        {->}{$\rightarrow$}{2}
        {<-}{$\leftarrow$}{2}
        {0}{{{\color{codeNumber}0}}}{1}
        {1}{{{\color{codeNumber}1}}}{1}
        {2}{{{\color{codeNumber}2}}}{1}
        {3}{{{\color{codeNumber}3}}}{1}
        {4}{{{\color{codeNumber}4}}}{1}
        {5}{{{\color{codeNumber}5}}}{1}
        {6}{{{\color{codeNumber}6}}}{1}
        {7}{{{\color{codeNumber}7}}}{1}
        {8}{{{\color{codeNumber}8}}}{1}
        {9}{{{\color{codeNumber}9}}}{1}
}

% Python style with line numbers (when needed)
\lstdefinestyle{pythonstylenumbered}{
    style=pythonstyle,
    numbers=left,
    xleftmargin=25pt
}

%------------------------------------------------------------------------------
%  MATH/PSEUDOCODE STYLE
%------------------------------------------------------------------------------
\lstdefinestyle{mathstyle}{
    basicstyle=\ttfamily\small,
    backgroundcolor=\color{codeBackground},
    keywordstyle=\color{codeKeyword}\bfseries,
    commentstyle=\color{codeComment}\itshape,
    mathescape=true,
    escapeinside={(*@}{@*)},
    numbers=left,
    numberstyle=\tiny\color{codeLineNum},
    numbersep=10pt,
    frame=single,
    framesep=5pt,
    rulecolor=\color{codeBorder},
    xleftmargin=20pt,
    xrightmargin=5pt,
    breaklines=true,
    showstringspaces=false,
    tabsize=4
}

%------------------------------------------------------------------------------
%  CONSOLE/TERMINAL STYLE
%------------------------------------------------------------------------------
\lstdefinestyle{consolestyle}{
    language=bash,
    basicstyle=\ttfamily\small\color{consoleText},
    backgroundcolor=\color{consoleBackground},
    keywordstyle=\color{consolePrompt}\bfseries,
    stringstyle=\color{consoleOutput},
    commentstyle=\color{codeComment},
    numbers=none,
    frame=single,
    framesep=8pt,
    rulecolor=\color{consoleBackground},
    xleftmargin=10pt,
    xrightmargin=10pt,
    aboveskip=10pt,
    belowskip=10pt,
    breaklines=true,
    showstringspaces=false
}

%------------------------------------------------------------------------------
%  JULIA STYLE
%------------------------------------------------------------------------------
\lstdefinestyle{juliastyle}{
    language=Python,  % Base on Python, customize below
    basicstyle=\ttfamily\small,
    backgroundcolor=\color{codeBackground},
    keywordstyle=\color{codeKeyword}\bfseries,
    stringstyle=\color{codeString},
    commentstyle=\color{codeComment}\itshape,
    morekeywords={function,end,struct,mutable,abstract,type,where,using,import,export,module,begin,let},
    numbers=left,
    numberstyle=\tiny\color{codeLineNum},
    numbersep=10pt,
    frame=single,
    framesep=5pt,
    rulecolor=\color{codeBorder},
    xleftmargin=20pt,
    xrightmargin=5pt,
    breaklines=true,
    showstringspaces=false,
    tabsize=4
}

%------------------------------------------------------------------------------
%  LATEX STYLE
%------------------------------------------------------------------------------
\lstdefinestyle{latexstyle}{
    language=[LaTeX]TeX,
    basicstyle=\ttfamily\small,
    backgroundcolor=\color{codeBackground},
    keywordstyle=\color{codeKeyword}\bfseries,
    stringstyle=\color{codeString},
    commentstyle=\color{codeComment}\itshape,
    texcsstyle=*\color{codeDecorator},
    numbers=left,
    numberstyle=\tiny\color{codeLineNum},
    numbersep=10pt,
    frame=single,
    framesep=5pt,
    rulecolor=\color{codeBorder},
    xleftmargin=20pt,
    xrightmargin=5pt,
    breaklines=true,
    showstringspaces=false
}

%------------------------------------------------------------------------------
%  JSON STYLE
%------------------------------------------------------------------------------
\lstdefinestyle{jsonstyle}{
    basicstyle=\ttfamily\small,
    backgroundcolor=\color{codeBackground},
    stringstyle=\color{codeString},
    numbers=left,
    numberstyle=\tiny\color{codeLineNum},
    numbersep=10pt,
    frame=single,
    framesep=5pt,
    rulecolor=\color{codeBorder},
    xleftmargin=20pt,
    xrightmargin=5pt,
    breaklines=true,
    showstringspaces=false,
    literate=
        *{:}{{{\color{codeOperator}{:}}}}{1}
        {,}{{{\color{codeOperator}{,}}}}{1}
        {\{}{{{\color{codeKeyword}{\{}}}}{1}
        {\}}{{{\color{codeKeyword}{\}}}}}{1}
        {[}{{{\color{codeKeyword}{[}}}}{1}
        {]}{{{\color{codeKeyword}{]}}}}{1}
}

%------------------------------------------------------------------------------
%  SET DEFAULT STYLE
%------------------------------------------------------------------------------
\lstset{style=pythonstyle}

%------------------------------------------------------------------------------
%  TCOLORBOX CODE ENVIRONMENTS
%------------------------------------------------------------------------------

% Python Code Box - Clean, modern style
\newtcblisting{pythoncode}[1][]{
    enhanced,
    breakable,
    colback=codeBackground,
    colframe=codeBackground,  % Same as background for borderless look
    arc=3mm,                  % Rounded corners
    boxrule=0pt,              % No border
    left=6pt,
    right=6pt,
    top=10pt,
    bottom=10pt,
    listing only,
    listing options={style=pythonstyle,#1}
}

% Python Code Box with line numbers
\newtcblisting{pythoncodenumbered}[1][]{
    enhanced,
    breakable,
    colback=codeBackground,
    colframe=codeBackground,
    arc=3mm,
    boxrule=0pt,
    left=6pt,
    right=6pt,
    top=10pt,
    bottom=10pt,
    listing only,
    listing options={style=pythonstylenumbered,#1}
}

% Console/Terminal Box
\newtcblisting{consolecode}[1][]{
    enhanced,
    breakable,
    colback=consoleBackground,
    colframe=consoleBackground,
    arc=2mm,
    boxrule=0pt,
    left=0pt,
    right=0pt,
    top=0pt,
    bottom=0pt,
    listing only,
    listing options={style=consolestyle,#1},
    overlay={
        \node[anchor=north east,inner sep=4pt,font=\footnotesize\color{consoleText}]
        at (frame.north east) {\faTerminal\ Terminal};
    }
}

% Math/Algorithm Box
\newtcblisting{algorithmcode}[1][]{
    enhanced,
    breakable,
    colback=codeBackground,
    colframe=primaryblue!30,
    arc=2mm,
    boxrule=0.5pt,
    left=0pt,
    right=0pt,
    top=0pt,
    bottom=0pt,
    listing only,
    listing options={style=mathstyle,#1}
}

% Generic Code Box with Title
\newtcblisting{codebox}[2][]{
    enhanced,
    breakable,
    colback=codeBackground,
    colframe=codeBorder,
    arc=2mm,
    boxrule=0.5pt,
    title=#2,
    fonttitle=\bfseries\small,
    coltitle=black,
    attach boxed title to top left={xshift=5mm,yshift=-2mm},
    boxed title style={
        colback=codeBackground,
        colframe=codeBorder,
        boxrule=0.5pt
    },
    left=0pt,
    right=0pt,
    top=5pt,
    bottom=0pt,
    listing only,
    listing options={style=pythonstyle,#1}
}

%------------------------------------------------------------------------------
%  INLINE CODE COMMAND
%------------------------------------------------------------------------------
\newcommand{\code}[1]{\texttt{\small\color{codeKeyword}#1}}
\newcommand{\pycode}[1]{\lstinline[style=pythonstyle]|#1|}

%------------------------------------------------------------------------------
%  FILE LISTING COMMAND
%------------------------------------------------------------------------------
\newcommand{\inputcode}[3][pythonstyle]{
    \lstinputlisting[style=#1,caption=#3]{#2}
}

%------------------------------------------------------------------------------
%  OUTPUT BOX (for showing program output) - Clean style
%------------------------------------------------------------------------------
\newtcolorbox{outputbox}[1][]{
    enhanced,
    breakable,
    colback=gray!8,
    colframe=gray!8,           % Borderless
    arc=3mm,
    boxrule=0pt,
    left=12pt,
    right=12pt,
    top=10pt,
    bottom=10pt,
    fontupper=\ttfamily\small\color{black!80}
}

%------------------------------------------------------------------------------
%  COMPARISON BOX (for before/after code)
%------------------------------------------------------------------------------
\newtcolorbox{codecompare}[1][]{
    enhanced,
    breakable,
    colback=white,
    colframe=codeBorder,
    arc=2mm,
    boxrule=0.5pt,
    sidebyside,
    sidebyside align=top,
    lefthand width=0.48\textwidth,
    #1
}

%------------------------------------------------------------------------------
%  FIGURE STYLING - Consistent plot appearance
%------------------------------------------------------------------------------
\pgfplotsset{
    book figure/.style={
        width=0.85\textwidth,
        height=0.5\textwidth,
        grid=major,
        grid style={gray!20, thin},
        tick label style={font=\small},
        label style={font=\small},
        legend style={
            font=\small,
            fill=white,
            fill opacity=0.9,
            draw=gray!40,
            rounded corners=2pt,
            cells={anchor=west},
        },
        every axis plot/.append style={line width=1.2pt},
        cycle list={
            {primaryblue, mark=*},
            {primaryred, mark=square*},
            {primarygreen!80!black, mark=triangle*},
            {accentorange, mark=diamond*},
        },
    }
}

%------------------------------------------------------------------------------
%  END OF PACKAGE
%------------------------------------------------------------------------------
\endinput
