%------------------------------------------------------------------------------
%  HELPER COMMANDS FOR DIAGRAMS
%------------------------------------------------------------------------------

% Draw a neural network layer with specified number of neurons
% Usage: \nnlayer{name}{x-pos}{y-pos}{num-neurons}{style}
\newcommand{\nnlayer}[5]{%
    \foreach \i in {1,...,#4} {
        \pgfmathsetmacro{\ypos}{#3 + (\i - 1 - (#4-1)/2) * 1.2}
        \node[#5] (#1-\i) at (#2, \ypos) {};
    }
}

% Draw connections between two layers
% Usage: \nnconnect{layer1}{n1}{layer2}{n2}{style}
\newcommand{\nnconnect}[5]{%
    \foreach \i in {1,...,#2} {
        \foreach \j in {1,...,#4} {
            \draw[#5] (#1-\i) -- (#3-\j);
        }
    }
}

% Draw a small coordinate system for vector plots
% Usage: \smallcoords{x-length}{y-length}
\newcommand{\smallcoords}[2]{%
    \draw[vectorplot/vp axis] (-0.3,0) -- (#1,0) node[right] {\footnotesize $x$};
    \draw[vectorplot/vp axis] (0,-0.3) -- (0,#2) node[above] {\footnotesize $y$};
    \node[vectorplot/vp origin] at (0,0) {};
}

% Draw a matrix grid
% Usage: \matrixgrid{rows}{cols}{cell-size}
\newcommand{\matrixgrid}[3]{%
    \foreach \i in {1,...,#1} {
        \foreach \j in {1,...,#2} {
            \draw[matrixviz/mv cell]
                ({(\j-1)*#3}, {-((\i-1)*#3)})
                rectangle ++({#3}, {-#3});
        }
    }
}

% Gradient descent step marker
% Usage: \gdstep{x}{y}{label}
\newcommand{\gdstep}[3]{%
    \node[losslandscape/ll point, label={[font=\scriptsize]above:#3}] at (#1,#2) {};
}

