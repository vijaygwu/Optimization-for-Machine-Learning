%------------------------------------------------------------------------------
%  SECTION 4: CHAPTER OPENER COMMAND
%------------------------------------------------------------------------------
% Creates a visually striking chapter opener with icon, tagline, and illustration

% Chapter opener background color
\definecolor{chapteropener@bg}{RGB}{240,248,255}  % Very light blue

\newcommand{\chapteropener}[3]{%
    % #1 = FontAwesome icon command (e.g., \faNetworkWired)
    % #2 = Tagline text
    % #3 = TikZ illustration code
    %
    \begin{tcolorbox}[
        enhanced,
        breakable=false,
        colback=chapteropener@bg,
        colframe=primaryblue,
        boxrule=0pt,
        frame hidden,
        borderline south={2pt}{0pt}{primaryblue},
        arc=0pt,
        left=15pt,
        right=15pt,
        top=20pt,
        bottom=15pt,
        before skip=0pt,
        after skip=20pt,
        width=\textwidth,
        %
        % Watermark with large faded illustration
        watermark graphics={},  % Clear default
        overlay={%
            % Faded TikZ illustration (right side, large)
            \begin{scope}[
                shift={(current bounding box.east)},
                xshift=-3cm,
                yshift=0cm,
                opacity=0.12,
                scale=1.8
            ]
                #3
            \end{scope}
        },
        %
        % Interior styling
        interior style={
            fill=chapteropener@bg
        }
    ]
    %
    % Large icon on the left
    \begin{minipage}[c]{0.12\textwidth}
        \centering
        {\fontsize{36pt}{40pt}\selectfont\textcolor{primaryblue!70}{#1}}
    \end{minipage}%
    \hfill
    %
    % Tagline text
    \begin{minipage}[c]{0.82\textwidth}
        \raggedright
        {\Large\itshape\textcolor{primaryblue!80!black}{#2}}
    \end{minipage}
    %
    \end{tcolorbox}
}

