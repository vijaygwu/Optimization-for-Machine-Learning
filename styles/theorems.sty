\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{styles/theorems}[2026/04/11 Theorem Environments Package]

%------------------------------------------------------------------------------
%  TCOLORBOX THEOREM STYLES
%------------------------------------------------------------------------------
\RequirePackage[most]{tcolorbox}
\RequirePackage{amsthm}

%------------------------------------------------------------------------------
%  THEOREM COUNTER
%------------------------------------------------------------------------------
\newcounter{theoremcounter}[chapter]
\renewcommand{\thetheoremcounter}{\thechapter.\arabic{theoremcounter}}

%------------------------------------------------------------------------------
%  DEFINITION ENVIRONMENT
%------------------------------------------------------------------------------
\newtcbtheorem[use counter=theoremcounter]{definition}{Definition}{
    enhanced,
    breakable=false,
    colback=defbackground,
    colframe=defframe,
    arc=2mm,
    boxrule=0.8pt,
    left=8pt,
    right=8pt,
    top=8pt,
    bottom=8pt,
    fonttitle=\bfseries\color{defframe!80!black},
    separator sign={\ ---},
    description font=\normalfont\itshape,
    before upper={\parindent0pt},
    attach boxed title to top left={xshift=5mm,yshift=-3mm},
    boxed title style={
        colback=defbackground,
        colframe=defframe,
        boxrule=0.5pt
    }
}{def}

