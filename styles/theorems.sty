%------------------------------------------------------------------------------
%  PROOF ENVIRONMENT (enhanced)
%------------------------------------------------------------------------------
\renewenvironment{proof}[1][\proofname]{
    \par\pushQED{\qed}
    \normalfont
    \topsep6\p@\@plus6\p@\relax
    \trivlist
    \item[\hskip\labelsep\itshape#1\@addpunct{.}]\ignorespaces
}{
    \popQED\endtrivlist\@endpefalse
}

% Proof box style (alternative)
\newtcolorbox{proofbox}[1][Proof]{
    enhanced,
    breakable=false,
    colback=white,
    colframe=black!30,
    arc=0mm,
    boxrule=0pt,
    borderline west={2pt}{0pt}{black!30},
    left=10pt,
    right=8pt,
    top=6pt,
    bottom=6pt,
    fonttitle=\itshape,
    title=#1,
    after upper={\hfill$\square$}
}

